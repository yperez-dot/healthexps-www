<section class="section">
  <div class="container">
    <div class="icon-heading">
      <div class="icon-circle">
        <svg viewBox="0 0 24 24" fill="none" stroke="#452068" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      </div>
      <h2>Su Medicare, Simplificado</h2>
    </div>
