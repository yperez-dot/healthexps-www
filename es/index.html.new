</section>

<!-- CÓMO FUNCIONA -->
<section class="section section-alt">
  <div class="container">
    <div class="icon-heading">
      <div class="icon-circle">
        <svg viewBox="0 0 24 24" fill="none" stroke="#452068" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
      </div>
      <h2>Cómo Trabajamos — 3 Pasos Simples</h2>
    </div>
